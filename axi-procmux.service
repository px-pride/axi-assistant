[Unit]
Description=Axi Procmux (process multiplexer)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/axi-assistant
EnvironmentFile=/home/ubuntu/axi-assistant/.env
ExecStart=/bin/bash -c 'exec "$(dirname "$AXI_RS_BINARY")/procmux" /home/ubuntu/axi-assistant/.bridge.sock'
Restart=on-failure
RestartSec=1
TimeoutStopSec=10
Environment="HOME=/home/ubuntu"

[Install]
WantedBy=default.target
