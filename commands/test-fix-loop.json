{
  "id": "test-fix-loop-001",
  "name": "test-fix-loop",
  "description": "Runs tests and fixes failures until all tests pass, with max iteration limit",
  "flowchart": {
    "blocks": {
      "start-5": {
        "id": "start-5",
        "type": "start",
        "name": "START",
        "position": {
          "x": 100,
          "y": 50
        }
      },
      "var-attempts": {
        "id": "var-attempts",
        "type": "variable",
        "name": "SET attempts=0",
        "position": {
          "x": 100,
          "y": 150
        },
        "variable_name": "attempts",
        "variable_value": "0",
        "variable_type": "int"
      },
      "var-max": {
        "id": "var-max",
        "type": "variable",
        "name": "SET max_attempts",
        "position": {
          "x": 100,
          "y": 250
        },
        "variable_name": "max_attempts",
        "variable_value": "10",
        "variable_type": "int"
      },
      "bash-run": {
        "id": "bash-run",
        "type": "bash",
        "name": "RUN ALL TESTS",
        "position": {
          "x": 100,
          "y": 350
        },
        "command": "./run_all_tests.sh &> test_results.txt",
        "capture_output": true,
        "output_variable": "testOutput",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": "exitCode"
      },
      "branch-pass": {
        "id": "branch-pass",
        "type": "branch",
        "name": "TESTS PASS?",
        "position": {
          "x": 100,
          "y": 450
        },
        "condition": "exitCode == 0"
      },
      "bash-tag": {
        "id": "bash-tag",
        "type": "bash",
        "name": "TAG SUCCESS",
        "position": {
          "x": 100,
          "y": 550
        },
        "command": "git tag \"all-tests-passing\" 2>/dev/null || true",
        "capture_output": false,
        "output_variable": "",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": ""
      },
      "end-5": {
        "id": "end-5",
        "type": "end",
        "name": "END",
        "position": {
          "x": 100,
          "y": 650
        }
      },
      "bash-increment": {
        "id": "bash-increment",
        "type": "bash",
        "name": "attempts++",
        "position": {
          "x": 350,
          "y": 450
        },
        "command": "echo $(({{attempts}}+1))",
        "capture_output": true,
        "output_variable": "attempts",
        "output_type": "int",
        "working_directory": "",
        "continue_on_error": false,
        "exit_code_variable": ""
      },
      "branch-max": {
        "id": "branch-max",
        "type": "branch",
        "name": "UNDER MAX?",
        "position": {
          "x": 350,
          "y": 550
        },
        "condition": "attempts < max_attempts"
      },
      "refresh-2": {
        "id": "refresh-2",
        "type": "refresh",
        "name": "REFRESH",
        "position": {
          "x": 500,
          "y": 550
        }
      },
      "prompt-diagnose": {
        "id": "prompt-diagnose",
        "type": "prompt",
        "name": "DIAGNOSE FAILURES",
        "position": {
          "x": 650,
          "y": 550
        },
        "prompt": "`./run_all_tests.sh` returned exit code {{exitCode}}. This is attempt {{attempts}} of {{max_attempts}}.\n\nThe output is in test_results.txt.\n\nAnalyze the test failures:\n1. Read the test output carefully\n2. Identify root causes\n3. Check if previous fixes were on the right track or introduced regressions\n4. Categorize: real bugs vs. test issues vs. design problems\n\nDO NOT fix anything yet - just diagnose.\n\nWrite your diagnosis to ./audits/TEST_FAILURES_DIAGNOSIS_{{attempts}}.md",
        "output_schema": null,
        "sound_effect": null
      },
      "prompt-fix": {
        "id": "prompt-fix",
        "type": "prompt",
        "name": "FIX FAILURES",
        "position": {
          "x": 650,
          "y": 650
        },
        "prompt": "Based on ./audits/TEST_FAILURES_DIAGNOSIS_{{attempts}}.md, fix the test failures.\n\nMake minimal, targeted changes:\n- Fix real bugs in the code\n- Fix incorrect tests if the code is actually correct\n- Don't over-engineer solutions\n- Don't break other functionality\n\nIf a previous commit tried to fix these issues but failed, determine if those changes should be reverted to reduce tech debt.",
        "output_schema": null,
        "sound_effect": null
      },
      "prompt-max-reached": {
        "id": "prompt-max-reached",
        "type": "prompt",
        "name": "MAX ATTEMPTS WARNING",
        "position": {
          "x": 350,
          "y": 750
        },
        "prompt": "WARNING: Maximum test fix attempts ({{max_attempts}}) reached but tests are still failing.\n\nPerform a final analysis:\n1. Review all previous diagnoses in ./audits/TEST_FAILURES_DIAGNOSIS_*.md\n2. Identify if there's a fundamental issue (architecture problem, wrong approach, etc.)\n3. Make one final targeted fix attempt\n4. Document the situation in ./audits/TEST_FIX_FINAL_STATUS.md\n\nThis is the last attempt.",
        "output_schema": null,
        "sound_effect": null
      }
    },
