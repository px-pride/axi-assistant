{
  "id": "requirement-validator-001",
  "name": "requirement-validator",
  "description": "Validates that all design doc requirements are satisfied",
  "flowchart": {
    "blocks": {
      "start-9": {
        "id": "start-9",
        "type": "start",
        "name": "START",
        "position": {
          "x": 100,
          "y": 50
        }
      },
      "prompt-extract": {
        "id": "prompt-extract",
        "type": "prompt",
        "name": "EXTRACT REQUIREMENTS",
        "position": {
          "x": 100,
          "y": 150
        },
        "prompt": "Read ./design_docs/$1 carefully.\n\nExtract ALL requirements, features, and specifications mentioned in the design doc.\n\nCreate a checklist at ./audits/REQUIREMENTS_CHECKLIST.md with:\n- Each requirement as a separate item\n- Clear, testable criteria for each\n- Organized by category (features, performance, security, etc.)\n\nDO NOT validate yet - just extract and document all requirements.",
        "output_schema": null,
        "sound_effect": null
      },
      "prompt-validate": {
        "id": "prompt-validate",
        "type": "prompt",
        "name": "VALIDATE REQUIREMENTS",
        "position": {
          "x": 100,
          "y": 250
        },
        "prompt": "Review the entire codebase against each requirement in ./audits/REQUIREMENTS_CHECKLIST.md\n\nFor each requirement:\n1. Determine if it's satisfied by the implementation\n2. Document evidence (which files/functions/tests prove it)\n3. Identify any gaps or partial implementations\n\nUpdate ./audits/REQUIREMENTS_CHECKLIST.md with:\n- [x] for satisfied requirements (with evidence)\n- [ ] for unsatisfied requirements (with gap description)\n\nOutput structured validation results:",
        "output_schema": {
          "type": "object",
          "properties": {
            "totalRequirements": {
              "type": "integer"
            },
            "satisfiedRequirements": {
              "type": "integer"
            },
            "unsatisfiedRequirements": {
              "type": "integer"
            },
            "partialRequirements": {
              "type": "integer"
            },
            "allSatisfied": {
              "type": "boolean"
            }
          },
          "required": ["totalRequirements", "satisfiedRequirements", "unsatisfiedRequirements", "allSatisfied"]
        },
        "sound_effect": null
      },
      "branch-satisfied": {
        "id": "branch-satisfied",
        "type": "branch",
        "name": "ALL SATISFIED?",
        "position": {
          "x": 150,
          "y": 350
        },
        "condition": "allSatisfied"
      },
      "prompt-report": {
        "id": "prompt-report",
        "type": "prompt",
        "name": "CREATE GAP REPORT",
        "position": {
          "x": 350,
          "y": 350
        },
        "prompt": "Create a detailed gap analysis report at ./audits/REQUIREMENTS_GAPS.md\n\nFor each unsatisfied or partial requirement:\n1. What's missing?\n2. Why is it missing? (oversight, technical challenge, etc.)\n3. How critical is this gap?\n4. Recommended action to address it\n\nPrioritize gaps as: CRITICAL, HIGH, MEDIUM, LOW",
        "output_schema": {
          "type": "object",
          "properties": {
            "criticalGaps": {
              "type": "integer"
            },
            "highGaps": {
              "type": "integer"
            },
            "hasCriticalGaps": {
              "type": "boolean"
            }
          },
          "required": ["criticalGaps", "hasCriticalGaps"]
        },
        "sound_effect": null
      },
      "branch-critical": {
        "id": "branch-critical",
        "type": "branch",
        "name": "CRITICAL GAPS?",
        "position": {
          "x": 350,
          "y": 450
        },
        "condition": "hasCriticalGaps"
      },
      "prompt-fix-critical": {
        "id": "prompt-fix-critical",
        "type": "prompt",
        "name": "FIX CRITICAL GAPS",
        "position": {
          "x": 550,
          "y": 450
        },
        "prompt": "Address CRITICAL gaps identified in ./audits/REQUIREMENTS_GAPS.md\n\nThese are essential requirements that must be implemented.\n\nImplement the missing functionality.\n\nUpdate ./audits/REQUIREMENTS_CHECKLIST.md as you complete each requirement.",
        "output_schema": null,
        "sound_effect": null
      },
      "refresh-3": {
        "id": "refresh-3",
        "type": "refresh",
        "name": "REFRESH",
        "position": {
          "x": 550,
          "y": 550
        }
      },
      "prompt-fix-high": {
        "id": "prompt-fix-high",
        "type": "prompt",
        "name": "FIX HIGH PRIORITY",
        "position": {
          "x": 350,
          "y": 650
        },
        "prompt": "Address HIGH priority gaps identified in ./audits/REQUIREMENTS_GAPS.md\n\nThese are important requirements that should be implemented.\n\nImplement the missing functionality.\n\nUpdate ./audits/REQUIREMENTS_CHECKLIST.md as you complete each requirement.",
        "output_schema": null,
        "sound_effect": null
      },
      "prompt-final-check": {
        "id": "prompt-final-check",
        "type": "prompt",
        "name": "FINAL VALIDATION",
        "position": {
          "x": 150,
          "y": 750
        },
        "prompt": "Perform a final validation of all requirements in ./audits/REQUIREMENTS_CHECKLIST.md\n\nVerify that:\n1. All critical and high priority requirements are now satisfied\n2. The implementation matches the design doc intent\n3. Any remaining gaps are documented and justified\n\nCreate final validation report at ./audits/FINAL_REQUIREMENTS_VALIDATION.md\n\nAre all critical requirements now satisfied?",
        "output_schema": {
          "type": "object",
          "properties": {
            "allCriticalSatisfied": {
              "type": "boolean"
            },
            "completionPercentage": {
              "type": "integer"
            }
          },
          "required": ["allCriticalSatisfied"]
        },
        "sound_effect": null
      },
      "end-9": {
        "id": "end-9",
        "type": "end",
        "name": "END",
        "position": {
          "x": 150,
          "y": 850
        }
      }
    },
