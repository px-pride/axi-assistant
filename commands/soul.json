        "name": "WAIT_FOR_USER",
        "position": {
          "x": 300,
          "y": 1550
        },
        "prompt": "[Automated flowchart step — output goes to the user.]\n\nList the specific changes you just made that require manual testing. For each change, state:\n- What was changed\n- What the user should do to test it (specific steps)\n- What a successful test looks like\n\nBe brief — use bullet points.",
        "output_schema": null,
        "sound_effect": null
      },
