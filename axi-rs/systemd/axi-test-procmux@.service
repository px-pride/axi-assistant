[Unit]
Description=Axi Test Procmux (%i)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/axi-tests/%i
ExecStart=/home/ubuntu/axi-tests/%i/axi-rs/target/release/procmux /home/ubuntu/axi-tests/%i/.bridge.sock
Restart=on-failure
RestartSec=1
TimeoutStopSec=10
Environment="HOME=/home/ubuntu"
