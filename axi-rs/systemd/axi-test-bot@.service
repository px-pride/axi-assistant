[Unit]
Description=Axi Test Bot (%i)
After=axi-test-procmux@%i.service
Wants=axi-test-procmux@%i.service
StartLimitBurst=5
StartLimitIntervalSec=300

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/axi-tests/%i
EnvironmentFile=/home/ubuntu/axi-tests/%i/.env
ExecStart=/home/ubuntu/axi-tests/%i/axi-rs/target/release/axi-bot
Restart=always
RestartPreventExitStatus=0 SIGTERM
SuccessExitStatus=42
RestartSec=2
TimeoutStopSec=15
Environment="HOME=/home/ubuntu"
Environment="PATH=/home/ubuntu/.cargo/bin:/home/ubuntu/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
