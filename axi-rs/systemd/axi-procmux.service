[Unit]
Description=Axi Process Multiplexer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/axi-assistant
ExecStart=/home/ubuntu/axi-assistant/axi-rs/target/release/procmux /home/ubuntu/axi-assistant/.bridge.sock
Restart=on-failure
RestartSec=1
TimeoutStopSec=10

[Install]
WantedBy=default.target
