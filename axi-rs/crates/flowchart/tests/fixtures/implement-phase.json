{
  "id": "implement-phase-001",
  "name": "implement-phase",
  "description": "Implements a single phase from the phase plan",
  "flowchart": {
    "blocks": {
      "start-2": {
        "id": "start-2",
        "type": "start",
        "name": "START",
        "position": {
          "x": 100,
          "y": 50
        }
      },
      "prompt-scaffold": {
        "id": "prompt-scaffold",
        "type": "prompt",
        "name": "SCAFFOLD",
        "position": {
          "x": 100,
          "y": 150
        },
        "prompt": "Read ./design_docs/phases/PHASE_$1.md\n\nCreate the file structure and scaffolding for this phase. Set up directory structure, create empty/skeleton files, add basic imports and structure.\n\nDO NOT implement full logic yet - just scaffolding.\n\nDocument what you created in ./progress-reports/PHASE_$1_SCAFFOLD.md",
        "output_schema": null,
        "sound_effect": null
      },
      "prompt-implement": {
        "id": "prompt-implement",
        "type": "prompt",
        "name": "IMPLEMENT",
        "position": {
          "x": 100,
          "y": 250
        },
        "prompt": "Now fully implement ./design_docs/phases/PHASE_$1.md\n\nIf ./progress-reports/PHASE_$1_PROGRESS.md exists, continue from where you left off.\n\nImplement all required functionality for this phase. Follow the design doc carefully.\n\nUpdate ./progress-reports/PHASE_$1_PROGRESS.md with your progress.\n\nWhen done, answer: Is this phase fully implemented according to its design doc?",
        "output_schema": {
          "type": "object",
          "properties": {
            "phaseComplete": {
              "type": "boolean"
            }
          },
          "required": ["phaseComplete"]
        },
        "sound_effect": null
      },
      "branch-done": {
        "id": "branch-done",
        "type": "branch",
        "name": "PHASE DONE?",
        "position": {
          "x": 150,
          "y": 350
        },
        "condition": "phaseComplete"
      },
      "prompt-continue": {
        "id": "prompt-continue",
        "type": "prompt",
        "name": "CONTINUE",
        "position": {
          "x": 350,
          "y": 350
        },
        "prompt": "Continue implementing ./design_docs/phases/PHASE_$1.md\n\nCheck ./progress-reports/PHASE_$1_PROGRESS.md for current status.\n\nComplete any remaining work for this phase.\n\nWhen done, answer: Is this phase fully implemented?",
        "output_schema": {
          "type": "object",
          "properties": {
            "phaseComplete": {
              "type": "boolean"
            }
          },
          "required": ["phaseComplete"]
        },
        "sound_effect": null
      },
      "prompt-review": {
        "id": "prompt-review",
        "type": "prompt",
        "name": "SELF REVIEW",
        "position": {
          "x": 150,
          "y": 450
        },
        "prompt": "Review the code you just implemented for PHASE_$1.\n\nCheck for:\n- Code quality issues\n- Obvious bugs or edge cases\n- Tech debt or over-engineering\n- Missing error handling\n- Code that doesn't match the design doc\n\nMake any necessary improvements.\n\nWrite a brief review summary to ./progress-reports/PHASE_$1_REVIEW.md",
        "output_schema": null,
        "sound_effect": null
      },
      "prompt-unit-tests": {
        "id": "prompt-unit-tests",
        "type": "prompt",
        "name": "UNIT TESTS",
        "position": {
          "x": 150,
          "y": 550
        },
        "prompt": "Create unit tests for the code implemented in PHASE_$1.\n\nFocus on testing the key functions/classes/components created in this phase.\n\nCreate tests in an appropriate location (e.g., ./tests/phase_$1/ or alongside the code).\n\nDon't run the tests yet - just create them.",
        "output_schema": null,
        "sound_effect": null
      },
      "bash-tag": {
        "id": "bash-tag",
        "type": "bash",
        "name": "TAG PHASE",
        "position": {
          "x": 150,
          "y": 650
        },
        "command": "git tag \"phase-$1-complete\" 2>/dev/null || true",
        "capture_output": false,
        "output_variable": "",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": ""
      },
      "end-2": {
