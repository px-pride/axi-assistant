{
  "id": "ad000002-deck-4000-8000-auto00000002",
  "name": "mil",
  "description": "Automatically execute cards from a deck with minimal human approval — only stops for very complex/ambiguous plans or critical research findings.",
  "flowchart": {
    "blocks": {
      "b0000001-start-4000-8000-000000000001": {
        "id": "b0000001-start-4000-8000-000000000001",
        "type": "start",
        "name": "START",
        "position": { "x": 150, "y": 50 }
      },
      "b0000002-get-4000-8000-000000000002": {
        "id": "b0000002-get-4000-8000-000000000002",
        "type": "prompt",
        "name": "GET TOP CARD",
        "position": { "x": 150, "y": 150 },
        "prompt": "Use the record_message tool to find the deck matching \"$1\" and get its top (first) incomplete card.\n\nReturn the card information as structured output. Set has_card to true if there is an incomplete card, or false if the deck is empty or all cards are complete.",
        "output_schema": {
          "type": "object",
          "properties": {
            "card_id": { "type": "string" },
            "card_text": { "type": "string" },
            "deck_id": { "type": "string" },
            "has_card": { "type": "boolean" }
          },
          "required": ["has_card"]
        },
        "sound_effect": null,
        "disable_auto_git": true
      },
      "b0000003-hasc-4000-8000-000000000003": {
        "id": "b0000003-hasc-4000-8000-000000000003",
        "type": "branch",
        "name": "HAS CARD?",
        "position": { "x": 150, "y": 270 },
        "condition": "has_card"
      },
      "b0000004-exec-4000-8000-000000000004": {
        "id": "b0000004-exec-4000-8000-000000000004",
        "type": "prompt",
        "name": "EXECUTE CARD",
        "position": { "x": 150, "y": 370 },
        "prompt": "Execute this task to the best of your ability:\n\n{{card_text}}\n\nWork thoroughly and completely. When finished, describe what you accomplished.",
        "output_schema": null,
        "sound_effect": null
      },
      "b0000005-chk-4000-8000-000000000005": {
        "id": "b0000005-chk-4000-8000-000000000005",
        "type": "prompt",
        "name": "CHECK APPROVAL",
        "position": { "x": 150, "y": 490 },
        "prompt": "You just worked on: {{card_text}}\n\nDetermine whether this work can be automatically marked complete, or whether it requires human review/approval.\n\nDefault to auto-completing. Only require approval in these cases:\n- Plan tasks: require approval ONLY if the plan involves very complex architecture or genuinely ambiguous requirements where you could easily go the wrong direction. Straightforward plans should auto-complete.\n- Research tasks: auto-complete UNLESS you uncovered something highly pertinent that the user would want to act on immediately (e.g. a critical finding, a decision point, something that changes project direction). Routine research summaries auto-complete.\n- Failed or incomplete work: ALWAYS requires approval\n\nEverything else (implementation, testing, git operations, etc.) should auto-complete.\n\nBias strongly toward auto-completing. The user wants momentum, not gatekeeping.",
        "output_schema": {
          "type": "object",
          "properties": {
            "auto_completable": { "type": "boolean" },
            "reason": { "type": "string" }
          },
          "required": ["auto_completable", "reason"]
        },
        "sound_effect": null,
        "disable_auto_git": true
      },
      "b0000006-appr-4000-8000-000000000006": {
        "id": "b0000006-appr-4000-8000-000000000006",
        "type": "branch",
        "name": "AUTO-COMPLETABLE?",
        "position": { "x": 150, "y": 610 },
        "condition": "auto_completable"
      },
      "b0000007-mark-4000-8000-000000000007": {
        "id": "b0000007-mark-4000-8000-000000000007",
        "type": "prompt",
        "name": "MARK COMPLETE",
        "position": { "x": 150, "y": 730 },
        "prompt": "Use the record_message tool to mark card {{card_id}} in deck {{deck_id}} as complete.\n\nBriefly confirm to the user that \"{{card_text}}\" has been auto-completed.",
        "output_schema": null,
        "sound_effect": null,
        "disable_auto_git": true
      },
      "b0000008-refr-4000-8000-000000000008": {
        "id": "b0000008-refr-4000-8000-000000000008",
        "type": "refresh",
        "name": "REFRESH",
        "position": { "x": 150, "y": 850 }
      },
      "b0000009-noti-4000-8000-000000000009": {
        "id": "b0000009-noti-4000-8000-000000000009",
        "type": "prompt",
        "name": "NOTIFY USER",
        "position": { "x": 400, "y": 610 },
        "prompt": "The work on \"{{card_text}}\" requires human review before it can be marked complete.\n\nReason: {{reason}}\n\nSend a clear, concise summary to the user explaining:\n1. What was accomplished\n2. Why human review is needed\n3. What specifically they should review or verify",
        "output_schema": null,
        "sound_effect": null,
        "disable_auto_git": true
      },
      "b000000a-exit-4000-8000-00000000000a": {
        "id": "b000000a-exit-4000-8000-00000000000a",
        "type": "exit",
        "name": "AWAIT HUMAN",
        "position": { "x": 400, "y": 730 },
        "exit_code": 0
      },
      "b000000b-end-4000-8000-00000000000b": {
        "id": "b000000b-end-4000-8000-00000000000b",
        "type": "end",
        "name": "DECK COMPLETE",
        "position": { "x": 400, "y": 270 }
      }
    },
