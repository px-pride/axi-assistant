        }
      },
      "3bb8897c-b0ff-426a-9217-c779d9ebbb44": {
        "id": "3bb8897c-b0ff-426a-9217-c779d9ebbb44",
        "type": "prompt",
        "name": "Fix Test Failures",
        "position": {
          "x": 250,
          "y": 500
        },
        "prompt": "Based on your analysis and diagnoses, fix all test failures in ./test_results/TEST_RESULTS_$1.{{prevTurn}} and make a progress report ./progress/PROGRESS_$1.TEST.{{prevTurn}}\n\nDO NOT USE TEMP DIRECTORIES. DO ALL WORK IN THIS DIRECTORY/SUBDIRECTORIES.\n\nDon't edit DESIGN_DOC.md, ARCHITECTURE.md, FEATURE_LIST_FULL.md, WAVE_BREAKDOWN.md, ./research, ./plans, ./progress, ./test-agents, ./test-results, ./how-to-be-a-good-coder",
