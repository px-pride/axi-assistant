        "type": "branch",
        "name": "No More Tests?",
        "position": {
          "x": 400,
          "y": 700
        },
        "condition": "moreTestsRequired"
      },
      "ee67bac5-a865-4210-b3ca-3429c4f4bb25": {
        "id": "ee67bac5-a865-4210-b3ca-3429c4f4bb25",
        "type": "variable",
        "name": "turn",
        "position": {
          "x": 400,
          "y": 400
        },
        "variable_name": "turn",
        "variable_value": "4",
        "variable_type": "int"
      },
      "6b870eed-baa0-41e9-a114-82533c8e154e": {
        "id": "6b870eed-baa0-41e9-a114-82533c8e154e",
        "type": "bash",
        "name": "Turn Increment",
        "position": {
          "x": 100,
          "y": 300
        },
        "command": "echo $(({{turn}}+1))",
        "capture_output": true,
        "output_variable": "turn",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": false,
        "exit_code_variable": ""
      },
      "63180d59-98b6-49f7-b387-fbc47c34b898": {
        "id": "63180d59-98b6-49f7-b387-fbc47c34b898",
        "type": "variable",
        "name": "prevTurn",
        "position": {
          "x": 100,
          "y": 400
        },
        "variable_name": "prevTurn",
        "variable_value": "{{turn}}",
        "variable_type": "int"
      },
      "3603ca83-c8b8-44d9-9bc4-e86f69c64fc1": {
        "id": "3603ca83-c8b8-44d9-9bc4-e86f69c64fc1",
        "type": "prompt",
        "name": "Run Tests",
        "position": {
          "x": 250,
          "y": 600
        },
        "prompt": "DO NOT USE TEMP DIRECTORIES. DO ALL WORK IN THIS DIRECTORY/SUBDIRECTORIES.\n\nFor each .md file in ./test-agents/test-agents-wave-$1, deploy an agent treating that file as an agents.md file. This agent will perform e2e testing on the codebase based on the behaviors prescribed in the .md file. Direct each agent to write results to its own uniquely identifiable output file in the subdirectory ./test_results/TEST_RESULTS_$1.{{turn}}\n\nDon't edit DESIGN_DOC.md, ARCHITECTURE.md, FEATURE_LIST_FULL.md, WAVE_BREAKDOWN.md, ./research, ./plans, ./test-agents, ./how-to-be-a-good-coder\n\nBased on the results in ./test_results/TEST_RESULTS_$1.{{turn}}, did ALL tests pass?",
        "output_schema": {
          "type": "object",
          "properties": {
            "testsPassed": {
              "type": "boolean"
            }
          },
          "required": [
            "testsPassed"
          ]
        },
        "sound_effect": null
      },
      "9b09e408-7f01-445c-985a-93d43cd8c530": {
        "id": "9b09e408-7f01-445c-985a-93d43cd8c530",
        "type": "prompt",
        "name": "Diagnose Test Failures",
        "position": {
          "x": 250,
          "y": 400
        },
        "prompt": "Don't edit anything. We are currently implementing Wave $1 of WAVE_BREAKDOWN.md. All previous waves have been implemented. Currently we are debugging test failures for our implementation of the current wave. Analyze and diagnose the test failures in ./test_results/TEST_RESULTS_$1.{{prevTurn}}",
        "output_schema": null,
        "sound_effect": null
      },
      "bc44f1ea-36cb-46c6-8675-8f7540c34248": {
        "id": "bc44f1ea-36cb-46c6-8675-8f7540c34248",
        "type": "refresh",
        "name": "Refresh",
        "position": {
          "x": 250,
