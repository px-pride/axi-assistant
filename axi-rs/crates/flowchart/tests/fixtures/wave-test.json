        }
      },
      "e641e202-f1cc-4e6d-a8fb-5890fa762420": {
        "id": "e641e202-f1cc-4e6d-a8fb-5890fa762420",
        "type": "prompt",
        "name": "Create Tests",
        "position": {
          "x": 400,
          "y": 600
        },
        "prompt": "DO NOT USE TEMP DIRECTORIES. DO ALL WORK IN THIS DIRECTORY/SUBDIRECTORIES.\n\n./test-agents contains subdirectories of agents.md-style files that instruct an agent to simulate an end user that performs end-to-end testing on the codebase. These should not be code inspection agents -- they should be end-to-end testers. These aren't agents that create test scripts -- they should directly interact with the program (may require tools/mcp). Add up to five new test agent files to subdir ./test-agents/test-agents-wave-$1, depending on how much testing is required. With each agent, you should be aiming to explore as much functionality at once of what's described in the Wave $1 of WAVE_BREAKDOWN.md and all waves leading up to it. You should also be aiming to have each agent act differently from each other (which requires cross-referencing against the current documents in ./test-agents). If there are very few agents so far, you should be creating agents that test core functionality and simulate realistic users. If there are many agents so far, you should be creating agents that explore edge case behavior.\n\nWhile building these test agents, you can reference ./how-to-be-a-good-coder, an organized encyclopedia of important knowledge specific to various coding topics. See ./how-to-be-a-good-coder/ABOUT.md for details.\n\nFor more information on features described in WAVE_BREAKDOWN.md, see FEATURE_LIST_FULL.md\n\nDon't deploy the test agents yet. Don't edit DESIGN_DOC.md, ARCHITECTURE.md, FEATURE_LIST_FULL.md, WAVE_BREAKDOWN.md, ./research, ./plans, ./test-results, ./how-to-be-a-good-coder\n\nAnswer this question when you're finished: will more test agents be required beyond the ones created so far for fully testing all functionality in Wave $1 of WAVE_BREAKDOWN.md (from top to bottom without deferring or deprioritizng any features)?",
        "output_schema": {
          "type": "object",
          "properties": {
            "moreTestsRequired": {
              "type": "boolean"
            }
          },
          "required": [
            "moreTestsRequired"
          ]
        },
        "sound_effect": null
      },
      "ea1a2621-7060-474c-a209-4cb54aaf676b": {
        "id": "ea1a2621-7060-474c-a209-4cb54aaf676b",
        "type": "end",
        "name": "End",
        "position": {
          "x": 400,
          "y": 800
        }
      },
      "3a8730c4-84ea-46a9-86e7-1ee7c3154ba9": {
