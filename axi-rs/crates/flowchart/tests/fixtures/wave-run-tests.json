      "9b09e408-7f01-445c-985a-93d43cd8c530": {
        "id": "9b09e408-7f01-445c-985a-93d43cd8c530",
        "type": "prompt",
        "name": "Diagnose Test Failures",
        "position": {
          "x": 250,
          "y": 400
        },
        "prompt": "We are currently implementing Wave $1 of WAVE_BREAKDOWN.md. All previous waves have been implemented. Currently we are debugging test failures for our implementation of the current wave. The test suite command run was `./run-tests.sh --wave=$1` and returned exit code {{testExitCode}}. The stdout/stderr streams were captured in `test_results_wave_$1.txt`. \n\nIf a previous commit already unsuccessfully attempted to fix these test failures, you must determine if those changes are actually necessary, and if not, revert them (to mitigate tech debt). Besides that, don't edit anything. Analyze and diagnose the test failures. Your analysis should be deep and comprehensive, with your results written to test-diagnoses/TEST_DIAGNOSIS_WAVE_$1.{{turn}}.txt \n\nStay consistent with ARCHITECTURE.md. Do not implement any fixes yet. Ultrathink.",
        "output_schema": null,
        "sound_effect": null
      },
      "bc44f1ea-36cb-46c6-8675-8f7540c34248": {
        "id": "bc44f1ea-36cb-46c6-8675-8f7540c34248",
        "type": "refresh",
        "name": "Refresh",
        "position": {
          "x": 250,
          "y": 300
        }
      },
      "3bb8897c-b0ff-426a-9217-c779d9ebbb44": {
        "id": "3bb8897c-b0ff-426a-9217-c779d9ebbb44",
        "type": "prompt",
        "name": "Fix Test Failures",
        "position": {
          "x": 250,
          "y": 500
        },
        "prompt": "Based on your analysis and diagnoses (written to test-diagnoses/TEST_DIAGNOSIS_WAVE_$1.{{turn}}.txt), fix all test failures and make a progress report ./progress/PROGRESS_$1.TEST.{{turn}}\n\nDO NOT RUN THE TESTS. It takes too long and background processes disrupt my workflow. I will handle running the tests. \n\nDo NOT do any cheating to fix tests. Don't do anything that would betray the user's expectations. That means no mocks, no placeholders, no stubs, no fallbacks, no failsafes. Stay consistent with ARCHITECTURE.md.\n\nDon't edit DESIGN_DOC.md, ARCHITECTURE.md, FEATURE_LIST_FULL.md, WAVE_BREAKDOWN.md, ./research, ./plans, ./progress, ./test-audits, ./how-to-be-a-good-coder",
        "output_schema": null,
        "sound_effect": null
      },
      "cb556580-d62b-4994-b8ce-689660cf3e52": {
        "id": "cb556580-d62b-4994-b8ce-689660cf3e52",
        "type": "bash",
        "name": "Run Tests",
        "position": {
          "x": 350,
          "y": 650
        },
        "command": "./run-tests.sh --wave=1 &> test_results_wave_$1.txt",
        "capture_output": true,
        "output_variable": "",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": "testExitCode"
      },
      "ac722864-bd19-4398-90ad-bf72c24cac47": {
        "id": "ac722864-bd19-4398-90ad-bf72c24cac47",
        "type": "bash",
        "name": "TAG COMPLETE",
        "position": {
          "x": 300,
          "y": 850
        },
        "command": "git tag \"wave-$1-testing-complete\" 2>/dev/null || true",
        "capture_output": true,
        "output_variable": "",
