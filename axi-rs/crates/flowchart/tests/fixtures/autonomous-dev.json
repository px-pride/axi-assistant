{
  "id": "autonomous-dev-001",
  "name": "autonomous-dev",
  "description": "Full autonomous development from DESIGN_DOC.md to complete implementation",
  "flowchart": {
    "blocks": {
      "start-main": {
        "id": "start-main",
        "type": "start",
        "name": "START",
        "position": {
          "x": 100,
          "y": 50
        }
      },
      "prompt-validate-design": {
        "id": "prompt-validate-design",
        "type": "prompt",
        "name": "VALIDATE DESIGN DOC",
        "position": {
          "x": 100,
          "y": 150
        },
        "prompt": "Read and validate ./design_docs/$1\n\nCheck that:\n1. Requirements are clear and specific\n2. Technical approach is sound\n3. No obvious contradictions or gaps\n4. Scope is well-defined\n\nIf there are serious issues with the design doc, note them. Otherwise, confirm it's ready for implementation.\n\nIs the design doc ready for implementation?",
        "output_schema": {
          "type": "object",
          "properties": {
            "designDocReady": {
              "type": "boolean"
            },
            "concerns": {
              "type": "string"
            }
          },
          "required": [
            "designDocReady"
          ]
        },
        "sound_effect": null
      },
      "branch-design-ready": {
        "id": "branch-design-ready",
        "type": "branch",
        "name": "DESIGN OK?",
        "position": {
          "x": 150,
          "y": 250
        },
        "condition": "designDocReady"
      },
      "prompt-design-issues": {
        "id": "prompt-design-issues",
        "type": "prompt",
        "name": "WARN DESIGN ISSUES",
        "position": {
          "x": 350,
          "y": 250
        },
        "prompt": "WARNING: Design doc has concerns: {{concerns}}\n\nDocument these concerns in ./audits/DESIGN_DOC_CONCERNS.md\n\nProceeding anyway, but implementation may need adjustments.",
        "output_schema": null,
        "sound_effect": null
      },
      "cmd-phase-planner": {
        "id": "cmd-phase-planner",
        "type": "command",
        "name": "PLAN PHASES",
        "position": {
          "x": 150,
          "y": 350
        },
        "command_name": "phase-planner",
        "arguments": "$1",
        "inherit_variables": false,
        "merge_output": true
      },
      "var-phase-index": {
        "id": "var-phase-index",
        "type": "variable",
        "name": "SET phase=0",
        "position": {
          "x": 150,
          "y": 450
        },
        "variable_name": "phase",
        "variable_value": "0",
        "variable_type": "int"
      },
      "bash-count-phases": {
        "id": "bash-count-phases",
        "type": "bash",
        "name": "COUNT PHASES",
        "position": {
          "x": 150,
          "y": 550
        },
        "command": "ls -1 ./design_docs/phases/PHASE_*.md 2>/dev/null | wc -l",
        "capture_output": true,
        "output_variable": "totalPhases",
        "output_type": "int",
        "working_directory": "",
        "continue_on_error": false,
        "exit_code_variable": ""
      },
      "branch-more-phases": {
        "id": "branch-more-phases",
        "type": "branch",
        "name": "MORE PHASES?",
        "position": {
          "x": 200,
          "y": 650
        },
        "condition": "phase < totalPhases"
      },
      "refresh-phase": {
        "id": "refresh-phase",
        "type": "refresh",
        "name": "REFRESH",
        "position": {
          "x": 400,
          "y": 750
        }
      },
      "cmd-implement-phase": {
        "id": "cmd-implement-phase",
        "type": "command",
        "name": "IMPLEMENT PHASE",
        "position": {
          "x": 550,
          "y": 750
        },
        "command_name": "implement-phase",
        "arguments": "{{phase}}",
        "inherit_variables": false,
        "merge_output": false
      },
      "bash-increment-phase": {
        "id": "bash-increment-phase",
        "type": "bash",
        "name": "phase++",
        "position": {
          "x": 700,
          "y": 650
        },
        "command": "echo $(({{phase}}+1))",
        "capture_output": true,
        "output_variable": "phase",
        "output_type": "int",
        "working_directory": "",
        "continue_on_error": false,
        "exit_code_variable": ""
      },
      "cmd-integration": {
        "id": "cmd-integration",
        "type": "command",
        "name": "INTEGRATION CHECK",
        "position": {
          "x": 200,
          "y": 850
        },
        "command_name": "integration-validator",
        "arguments": "$1",
        "inherit_variables": false,
        "merge_output": false
      },
      "cmd-test-suite": {
        "id": "cmd-test-suite",
        "type": "command",
        "name": "BUILD TEST SUITE",
        "position": {
          "x": 200,
          "y": 950
        },
        "command_name": "test-suite-builder",
        "arguments": "$1",
        "inherit_variables": false,
        "merge_output": false
      },
      "cmd-test-loop": {
        "id": "cmd-test-loop",
        "type": "command",
        "name": "TEST & FIX LOOP",
        "position": {
          "x": 200,
          "y": 1050
        },
        "command_name": "test-fix-loop",
        "arguments": "",
        "inherit_variables": false,
        "merge_output": false
      },
      "refresh-audit": {
        "id": "refresh-audit",
        "type": "refresh",
        "name": "REFRESH",
        "position": {
          "x": 200,
          "y": 1150
        }
      },
      "cmd-quality": {
        "id": "cmd-quality",
