        "merge_output": false
      },
      "cmd-deps": {
        "id": "cmd-deps",
        "type": "command",
        "name": "MANAGE DEPENDENCIES",
        "position": {
          "x": 200,
          "y": 1550
        },
        "command_name": "dependency-manager",
        "arguments": "",
        "inherit_variables": false,
        "merge_output": false
      },
      "refresh-validate": {
        "id": "refresh-validate",
        "type": "refresh",
        "name": "REFRESH",
        "position": {
          "x": 200,
          "y": 1650
        }
      },
      "cmd-requirements": {
        "id": "cmd-requirements",
        "type": "command",
        "name": "VALIDATE REQUIREMENTS",
        "position": {
          "x": 200,
          "y": 1750
        },
        "command_name": "requirement-validator",
        "arguments": "$1",
        "inherit_variables": false,
        "merge_output": true
      },
      "branch-requirements-met": {
        "id": "branch-requirements-met",
        "type": "branch",
        "name": "REQUIREMENTS MET?",
        "position": {
          "x": 200,
          "y": 1850
        },
        "condition": "allCriticalSatisfied"
      },
      "prompt-final-gaps": {
        "id": "prompt-final-gaps",
        "type": "prompt",
        "name": "ADDRESS FINAL GAPS",
        "position": {
          "x": 450,
          "y": 1850
        },
        "prompt": "Critical requirements are still not satisfied!\n\nReview ./audits/FINAL_REQUIREMENTS_VALIDATION.md and make final targeted fixes.\n\nThis is the last chance to address gaps before completion.",
        "output_schema": null,
        "sound_effect": null
      },
      "bash-final-test": {
        "id": "bash-final-test",
        "type": "bash",
        "name": "FINAL SMOKE TEST",
        "position": {
          "x": 200,
          "y": 1950
        },
        "command": "./run_all_tests.sh &> final_test_results.txt",
        "capture_output": true,
        "output_variable": "",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": "finalTestExitCode"
      },
      "branch-final-test": {
        "id": "branch-final-test",
        "type": "branch",
        "name": "FINAL TEST PASS?",
        "position": {
          "x": 200,
          "y": 2050
        },
        "condition": "finalTestExitCode == 0"
      },
      "prompt-final-emergency": {
        "id": "prompt-final-emergency",
        "type": "prompt",
        "name": "EMERGENCY FIX",
        "position": {
          "x": 450,
          "y": 2050
        },
        "prompt": "WARNING: Final smoke test failed!\n\nReview final_test_results.txt and make emergency fixes.\n\nIdentify critical issues and fix them quickly.",
        "output_schema": null,
        "sound_effect": null
      },
      "bash-retest": {
        "id": "bash-retest",
        "type": "bash",
        "name": "RETEST",
        "position": {
          "x": 450,
          "y": 2150
        },
        "command": "./run_all_tests.sh &> final_test_results_retry.txt",
        "capture_output": true,
        "output_variable": "",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": "retestExitCode"
      },
      "prompt-completion-report": {
        "id": "prompt-completion-report",
        "type": "prompt",
        "name": "COMPLETION REPORT",
        "position": {
          "x": 200,
          "y": 2250
        },
        "prompt": "Create a final completion report at ./COMPLETION_REPORT.md\n\nSummarize:\n1. What was implemented (reference phases)\n2. Test results (pass rate, coverage if available)\n3. Requirements satisfaction (reference validation report)\n4. Known limitations or gaps (if any)\n5. Documentation created\n6. How to use/run the project\n\nThis is the final deliverable summary.",
        "output_schema": null,
        "sound_effect": null
      },
      "bash-tag-complete": {
        "id": "bash-tag-complete",
        "type": "bash",
        "name": "TAG COMPLETE",
        "position": {
          "x": 200,
          "y": 2350
        },
        "command": "git tag \"autonomous-dev-complete\" 2>/dev/null || true",
        "capture_output": false,
        "output_variable": "",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": ""
      },
      "end-main": {
        "id": "end-main",
        "type": "end",
        "name": "END",
        "position": {
          "x": 200,
          "y": 2450
        }
      }
