{
  "id": "dependency-manager-001",
  "name": "dependency-manager",
  "description": "Validates and manages project dependencies",
  "flowchart": {
    "blocks": {
      "start-8": {
        "id": "start-8",
        "type": "start",
        "name": "START",
        "position": {
          "x": 100,
          "y": 50
        }
      },
      "prompt-analyze": {
        "id": "prompt-analyze",
        "type": "prompt",
        "name": "ANALYZE DEPENDENCIES",
        "position": {
          "x": 100,
          "y": 150
        },
        "prompt": "Analyze the project's dependencies.\n\nCheck:\n1. Are all dependencies properly declared in the appropriate files (package.json, requirements.txt, Cargo.toml, go.mod, etc.)?\n2. Are there any missing dependencies that the code uses?\n3. Are there any unused dependencies that should be removed?\n4. Are version constraints appropriate?\n5. Are there lock files (package-lock.json, poetry.lock, etc.) and are they up to date?\n\nWrite analysis to ./audits/DEPENDENCY_ANALYSIS.md\n\nAnswer: Are there dependency issues?",
        "output_schema": {
          "type": "object",
          "properties": {
            "hasIssues": {
              "type": "boolean"
            },
            "missingDeps": {
              "type": "integer"
            },
            "unusedDeps": {
              "type": "integer"
            }
          },
          "required": ["hasIssues"]
        },
        "sound_effect": null
      },
      "branch-issues": {
        "id": "branch-issues",
        "type": "branch",
        "name": "HAS ISSUES?",
        "position": {
          "x": 150,
          "y": 250
        },
        "condition": "hasIssues"
      },
      "prompt-fix": {
        "id": "prompt-fix",
        "type": "prompt",
        "name": "FIX DEPENDENCIES",
        "position": {
          "x": 350,
          "y": 250
        },
        "prompt": "Fix dependency issues identified in ./audits/DEPENDENCY_ANALYSIS.md\n\n- Add missing dependencies\n- Remove unused dependencies\n- Fix version constraints if needed\n- Update dependency files\n\nDon't run install yet.",
        "output_schema": null,
        "sound_effect": null
      },
      "bash-install": {
        "id": "bash-install",
        "type": "bash",
        "name": "INSTALL DEPS",
        "position": {
          "x": 150,
          "y": 350
        },
        "command": "# Auto-detect package manager and install\nif [ -f package.json ]; then\n  npm install\nelif [ -f requirements.txt ]; then\n  pip install -r requirements.txt\nelif [ -f Cargo.toml ]; then\n  cargo build\nelif [ -f go.mod ]; then\n  go mod download\nelif [ -f composer.json ]; then\n  composer install\nelse\n  echo \"No recognized dependency file found\"\nfi",
        "capture_output": true,
        "output_variable": "",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": "installExitCode"
      },
      "branch-install-ok": {
        "id": "branch-install-ok",
        "type": "branch",
        "name": "INSTALL OK?",
        "position": {
          "x": 150,
          "y": 450
        },
        "condition": "installExitCode == 0"
      },
      "prompt-fix-install": {
        "id": "prompt-fix-install",
        "type": "prompt",
        "name": "FIX INSTALL ERRORS",
        "position": {
          "x": 400,
          "y": 450
        },
        "prompt": "Dependency installation failed!\n\nReview the error output and fix issues:\n- Version conflicts\n- Incompatible dependencies\n- Missing system dependencies\n- Network issues\n\nUpdate dependency files as needed.",
        "output_schema": null,
        "sound_effect": null
      },
      "bash-build": {
        "id": "bash-build",
        "type": "bash",
        "name": "VERIFY BUILD",
        "position": {
          "x": 150,
          "y": 550
        },
        "command": "# Try to build/compile if applicable\nif [ -f package.json ] && grep -q '\"build\"' package.json; then\n  npm run build\nelif [ -f Cargo.toml ]; then\n  cargo build\nelif [ -f go.mod ]; then\n  go build ./...\nelse\n  # No build step needed\n  exit 0\nfi",
        "capture_output": true,
        "output_variable": "",
        "output_type": "string",
        "working_directory": "",
        "continue_on_error": true,
        "exit_code_variable": "buildExitCode"
      },
      "branch-build-ok": {
        "id": "branch-build-ok",
        "type": "branch",
        "name": "BUILD OK?",
        "position": {
          "x": 150,
          "y": 650
        },
        "condition": "buildExitCode == 0"
      },
      "prompt-fix-build": {
        "id": "prompt-fix-build",
        "type": "prompt",
        "name": "FIX BUILD ERRORS",
        "position": {
          "x": 400,
          "y": 650
        },
        "prompt": "Build failed after installing dependencies!\n\nThis could indicate:\n- Code issues\n- Missing build dependencies\n- Configuration problems\n\nFix the build errors.",
        "output_schema": null,
        "sound_effect": null
      },
      "prompt-security": {
        "id": "prompt-security",
        "type": "prompt",
        "name": "CHECK SECURITY",
        "position": {
          "x": 150,
          "y": 750
        },
        "prompt": "Check for security vulnerabilities in dependencies.\n\nIf the project uses:\n- npm: Review any npm audit warnings\n- pip: Consider known CVEs\n- Other: Check for known vulnerabilities\n\nDocument any security concerns in ./audits/DEPENDENCY_SECURITY.md\n\nIf there are critical vulnerabilities, note them. Otherwise, document that dependencies appear secure.",
        "output_schema": null,
        "sound_effect": null
      },
      "end-8": {
        "id": "end-8",
        "type": "end",
        "name": "END",
        "position": {
          "x": 150,
          "y": 850
        }
      }
    },
