  "name": "algorithm",
  "description": "Task execution methodology — assesses effort, defines success criteria, builds, verifies, and loops until done.",
  "flowchart": {
    "blocks": {
      "e3f86787-2866-400b-93f5-066d652286fa": {
        "id": "e3f86787-2866-400b-93f5-066d652286fa",
        "type": "start",
        "name": "START",
        "position": {
          "x": 300,
          "y": 50
        }
      },
      "c4035521-eea1-482c-b901-965f925aa93d": {
        "id": "c4035521-eea1-482c-b901-965f925aa93d",
        "type": "prompt",
        "name": "EFFORT_ASSESS",
        "position": {
          "x": 300,
          "y": 150
        },
        "prompt": "[Automated flowchart step — not a user message.]\n\nAssess the effort required for this task:\n$1\n\nCategories:\n- quick: under 1 minute — lookups, small edits, simple questions\n- standard: 1-5 minutes — bug fixes, single features, focused changes\n- extended: 5-15 minutes — multi-file changes, complex features\n- deep: over 15 minutes — major features, refactors, investigations\n\nSet isQuick=true if quick. Set needsPlan=true if extended or deep. Set isDeep=true if deep.",
        "output_schema": {
          "type": "object",
          "properties": {
            "isQuick": { "type": "boolean" },
            "needsPlan": { "type": "boolean" },
            "isDeep": { "type": "boolean" }
          },
          "required": ["isQuick", "needsPlan", "isDeep"]
        },
        "sound_effect": null
      },
      "efd9abbb-8330-42d3-af91-b353d87e5983": {
        "id": "efd9abbb-8330-42d3-af91-b353d87e5983",
        "type": "branch",
        "name": "IS_QUICK?",
        "position": {
          "x": 300,
          "y": 250
        },
        "condition": "isQuick"
      },
      "a7adbf2c-9ffb-4025-8c2b-039fea9048d7": {
        "id": "a7adbf2c-9ffb-4025-8c2b-039fea9048d7",
        "type": "prompt",
        "name": "DO_IT",
        "position": {
          "x": 300,
          "y": 350
        },
        "prompt": "[Automated flowchart step — output goes to the user.]\n\nExecute this task:\n$1",
        "output_schema": null,
        "sound_effect": null
      },
      "682b9b03-1ac2-4eae-b932-5c03196f41b9": {
        "id": "682b9b03-1ac2-4eae-b932-5c03196f41b9",
        "type": "end",
        "name": "END_QUICK",
        "position": {
          "x": 300,
          "y": 450
        }
      },
      "183db138-50a3-4b75-868e-9cc9bf0864c8": {
        "id": "183db138-50a3-4b75-868e-9cc9bf0864c8",
        "type": "prompt",
        "name": "OBSERVE",
        "position": {
          "x": 600,
          "y": 250
        },
        "prompt": "[Automated flowchart step — not a user message.]\n\nDefine 3-5 testable pass/fail criteria for this task. Include one anti-criterion. Bullet points only, no elaboration.\n$1",
        "output_schema": {
          "type": "object",
          "properties": {
            "criteria": {
              "type": "string"
            }
          },
          "required": ["criteria"]
