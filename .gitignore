# INVERTED / ALLOWLIST-STYLE GITIGNORE
#
# This gitignore is inverted: everything is ignored by default, and only
# explicitly-allowlisted paths are eligible to be tracked. The goal is
# to minimize the risk of a rogue agent (or human) accidentally staging
# sensitive data, runtime state, build artifacts, or personal scratch
# files.
#
# To track a new top-level path, add a `!/name` negation below. To add
# a tracked file inside an otherwise-ignored subtree (like .claude/),
# negate each parent directory first, then the target.

# --- Ignore everything at the repo root ---
/*

# --- Allowlisted top-level directories ---
!/.github/
!/axi/
!/bin/
!/commands/
!/docs/
!/extensions/
!/packages/
!/prompts/
!/scripts/
!/tests/

# --- Allowlisted top-level files ---
!/.env.template
!/.gitignore
!/.pre-commit-config.yaml
!/README.md
!/axi-bot.service
!/axi-procmux.service
!/axi-test@.service
!/axi_test.py
!/docker-compose.yml
!/pyproject.toml
!/pyrightconfig.json
!/pytest.ini
!/ruff.toml
!/uv.lock

# --- .claude/: track commands/ and skills/, hide runtime state ---
!/.claude/
/.claude/*
!/.claude/commands/
!/.claude/skills/

# --- Build / cache artifacts anywhere in the tree ---
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.venv/
**/dist/
**/build/
**/target/

# --- Explicit exclusions inside allowlisted directories ---
/scripts/replay_minflow_ops.py
