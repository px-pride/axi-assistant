def jwt_claims(token):
    parts = token.split(".")
    if len(parts) != 3:
        return {}
    payload = parts[1] + "=" * (-len(parts[1]) % 4)
    try:
        return json.loads(base64.urlsafe_b64decode(payload.encode("ascii")))
    except Exception:
        return {}


def extract_account_id(tokens):
    if tokens.get("account_id"):
        return tokens["account_id"]

    for key in ("id_token", "access_token"):
        claims = jwt_claims(tokens.get(key, ""))
        if not claims:
            continue

        account_id = claims.get("chatgpt_account_id")
        if account_id:
            return account_id

        nested = claims.get("https://api.openai.com/auth")
        if isinstance(nested, dict) and nested.get("chatgpt_account_id"):
            return nested["chatgpt_account_id"]

        orgs = claims.get("organizations")
        if isinstance(orgs, list) and orgs and isinstance(orgs[0], dict):
            if orgs[0].get("id"):
                return orgs[0]["id"]

    return ""


def atomic_write_json(path, data):
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2) + "\n")
    tmp.chmod(0o600)
    tmp.replace(path)


class CodexAuth:
    def __init__(self, auth_path):
        self.auth_path = Path(auth_path).expanduser()
        self._cached = None
        self._cached_mtime = None

    def _read_auth(self):
        stat = self.auth_path.stat()
        if self._cached is None or self._cached_mtime != stat.st_mtime:
            self._cached = json.loads(self.auth_path.read_text())
            self._cached_mtime = stat.st_mtime
        return self._cached

    def _refresh(self, data):
        tokens = data.get("tokens") or {}
        refresh_token = tokens.get("refresh_token")
        if not refresh_token:
            raise RuntimeError("Codex auth is expired and no refresh_token is present")

        body = urllib.parse.urlencode({
            "grant_type": "refresh_token",
            "refresh_token": refresh_token,
            "client_id": CLIENT_ID,
        }).encode("utf-8")
        req = urllib.request.Request(
            TOKEN_URL,
            data=body,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=30) as resp:
            refreshed = json.loads(resp.read().decode("utf-8"))

        tokens.update({
            "access_token": refreshed["access_token"],
            "id_token": refreshed.get("id_token", tokens.get("id_token", "")),
            "refresh_token": refreshed.get("refresh_token", refresh_token),
        })
        if "account_id" not in tokens:
            account_id = extract_account_id(tokens)
            if account_id:
                tokens["account_id"] = account_id

        data["tokens"] = tokens
        data["auth_mode"] = data.get("auth_mode", "chatgpt")
        data["OPENAI_API_KEY"] = data.get("OPENAI_API_KEY")
        data["last_refresh"] = datetime.now(UTC).isoformat().replace("+00:00", "Z")
        atomic_write_json(self.auth_path, data)
        self._cached = data
        self._cached_mtime = self.auth_path.stat().st_mtime
        return tokens

    def get(self):
        data = self._read_auth()
        tokens = data.get("tokens") or {}
        access_token = tokens.get("access_token")
        if not access_token:
            raise RuntimeError(f"no access_token in {self.auth_path}")

        claims = jwt_claims(access_token)
        exp = claims.get("exp")
        if isinstance(exp, (int, float)) and exp <= time.time() + 120:
            tokens = self._refresh(data)

        account_id = extract_account_id(tokens)
        return tokens["access_token"], account_id


def content_text(content):
    if content is None:
        return ""
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        pieces = []
        for part in content:
            if not isinstance(part, dict):
                continue
            if part.get("type") in ("text", "input_text"):
                pieces.append(part.get("text", ""))
            elif part.get("type") == "image_url":
                image = part.get("image_url") or {}
                pieces.append(f"[image: {image.get('url', '')}]")
        return "\n".join(p for p in pieces if p)
    return json.dumps(content, separators=(",", ":"))


def responses_content(role, content):
    text_type = "output_text" if role == "assistant" else "input_text"
    if content is None:
        return ""
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return content_text(content)

    converted = []
    for part in content:
        if not isinstance(part, dict):
            continue

        part_type = part.get("type")
        if part_type in ("text", "input_text", "output_text"):
            text = part.get("text", "")
            if text:
                converted.append({"type": text_type, "text": text})
        elif part_type == "image_url":
            image = part.get("image_url") or {}
            if image.get("url"):
                converted.append({"type": "input_image", "image_url": image["url"]})
        elif part_type in ("input_image", "input_file", "computer_screenshot"):
            converted.append(part)

    return converted or ""


def responses_tools(tools):
    converted = []
    for tool in tools or []:
        if not isinstance(tool, dict):
            continue

        if tool.get("type") == "function" and isinstance(tool.get("function"), dict):
            function = tool["function"]
            item = {
                "type": "function",
                "name": function.get("name", ""),
                "parameters": function.get("parameters", {"type": "object", "properties": {}}),
            }
            if function.get("description"):
                item["description"] = function["description"]
            if item["name"]:
                converted.append(item)
        elif tool.get("name"):
            converted.append(tool)

    return converted


def responses_tool_choice(tool_choice):
    if not isinstance(tool_choice, dict):
        return tool_choice
    if tool_choice.get("type") == "function" and isinstance(tool_choice.get("function"), dict):
        name = tool_choice["function"].get("name")
        return {"type": "function", "name": name} if name else "auto"
    return tool_choice


def normalize_reasoning_effort(value):
    if value is None:
        return None
    normalized = str(value).strip().lower().replace("-", "_")
    aliases = {
        "minimal": "low",
        "x_high": "xhigh",
        "extra_high": "xhigh",
        "max": "xhigh",
        "maximum": "xhigh",
    }
    normalized = aliases.get(normalized, normalized)
    if normalized in ("low", "medium", "high", "xhigh"):
        return normalized
    return None


def extract_reasoning_effort(body):
    reasoning = body.get("reasoning")
    if isinstance(reasoning, dict):
        effort = normalize_reasoning_effort(reasoning.get("effort"))
        if effort:
            return effort

    for key in ("reasoning_effort", "effort"):
        effort = normalize_reasoning_effort(body.get(key))
        if effort:
            return effort

    return normalize_reasoning_effort(DEFAULT_REASONING_EFFORT)


def chat_to_responses(body):
    instructions = []
    items = []

    for msg in body.get("messages") or []:
        if not isinstance(msg, dict):
            continue
        role = msg.get("role", "")
        content = msg.get("content")
        if role in ("system", "developer"):
            text = content_text(content)
            if text:
                instructions.append(text)
        elif role == "user":
            items.append({"role": role, "content": responses_content(role, content)})
        elif role == "assistant":
            if content:
                items.append({"role": role, "content": responses_content(role, content)})
            for tool_call in msg.get("tool_calls") or []:
                if not isinstance(tool_call, dict):
                    continue
                function = tool_call.get("function") or {}
                items.append({
                    "type": "function_call",
                    "call_id": tool_call.get("id", ""),
                    "name": function.get("name", ""),
                    "arguments": function.get("arguments", ""),
                })
        elif role == "tool":
            tool_text = content_text(content)
            if tool_text:
                call_id = msg.get("tool_call_id", "")
                if call_id:
                    items.append({"type": "function_call_output", "call_id": call_id, "output": tool_text})
                else:
                    items.append({"role": "user", "content": f"Tool result:\n{tool_text}"})

    result = {
        "model": body.get("model", ""),
        "instructions": "\n".join(instructions) or "You are a helpful assistant.",
        "input": items,
        "store": False,
        "stream": True,
    }

    if "tools" in body:
        tools = responses_tools(body.get("tools"))
        if tools:
            result["tools"] = tools
    if "tool_choice" in body:
        result["tool_choice"] = responses_tool_choice(body["tool_choice"])
    if "parallel_tool_calls" in body:
        result["parallel_tool_calls"] = body["parallel_tool_calls"]

    effort = extract_reasoning_effort(body)
    if effort:
        result["reasoning"] = {"effort": effort}

    return result


def openai_usage(responses_usage):
    usage = responses_usage or {}
    prompt_tokens = usage.get("prompt_tokens", usage.get("input_tokens", 0)) or 0
    completion_tokens = usage.get("completion_tokens", usage.get("output_tokens", 0)) or 0
    total_tokens = usage.get("total_tokens", prompt_tokens + completion_tokens) or 0
    return {
        "prompt_tokens": int(prompt_tokens),
        "completion_tokens": int(completion_tokens),
        "total_tokens": int(total_tokens),
    }


def reasoning_summary_text(item):
    summary = item.get("summary")
    if not isinstance(summary, list):
        return ""
    pieces = []
    for part in summary:
        if isinstance(part, str):
            pieces.append(part)
            continue
        if not isinstance(part, dict):
            continue
        text = part.get("text")
        if text:
            pieces.append(str(text))
            continue
        content = part.get("content")
        if isinstance(content, str) and content:
            pieces.append(content)
            continue
        if isinstance(content, list):
            for child in content:
                if isinstance(child, str):
                    pieces.append(child)
                elif isinstance(child, dict) and child.get("text"):
                    pieces.append(str(child["text"]))
    return "".join(pieces)


def response_to_chat_completion(resp, fallback_text="", tool_calls=None):
    status = resp.get("status", "completed")
    text = resp.get("output_text")
    if text is None:
        text = fallback_text
    tool_calls = tool_calls or []
    message = {"role": "assistant", "content": None if tool_calls else (text or "")}
    if tool_calls:
        message["tool_calls"] = tool_calls
    return {
        "id": resp.get("id", f"chatcmpl-{int(time.time())}"),
        "object": "chat.completion",
        "created": int(resp.get("created_at", time.time())),
        "model": resp.get("model", ""),
        "choices": [{
            "index": 0,
            "message": message,
            "finish_reason": "tool_calls" if tool_calls else ("stop" if status == "completed" else "length"),
        }],
        "usage": openai_usage(resp.get("usage")),
    }


def parse_completed_response(raw):
    accumulated_text = []
    accumulated_reasoning = []
    completed = None
    tool_order = []
    tool_calls_by_item = {}
    for line in raw.decode("utf-8", errors="replace").splitlines():
        if not line.startswith("data: "):
            continue
        data = line[6:].strip()
        if not data or data == "[DONE]":
            continue
        try:
            event = json.loads(data)
        except json.JSONDecodeError:
            continue
        event_type = event.get("type")
        if event_type == "response.output_text.delta":
            accumulated_text.append(event.get("delta", ""))
        elif event_type == "response.reasoning_text.delta":
            delta = event.get("delta", "")
            if delta:
                accumulated_reasoning.append(delta)
        elif event_type == "response.output_item.added":
            item = event.get("item") or {}
            if item.get("type") == "reasoning":
                summary_text = reasoning_summary_text(item)
                if summary_text:
                    accumulated_reasoning.append(summary_text)
            elif item.get("type") == "function_call":
                item_id = item.get("id") or str(event.get("output_index", len(tool_order)))
                tool_order.append(item_id)
                tool_calls_by_item[item_id] = {
                    "id": item.get("call_id", item_id),
                    "type": "function",
                    "function": {"name": item.get("name", ""), "arguments": item.get("arguments", "") or ""},
                }
        elif event_type == "response.function_call_arguments.delta":
            item_id = event.get("item_id")
            if item_id in tool_calls_by_item:
                tool_calls_by_item[item_id]["function"]["arguments"] += event.get("delta", "")
        elif event_type == "response.function_call_arguments.done":
            item_id = event.get("item_id")
            if item_id in tool_calls_by_item:
                tool_calls_by_item[item_id]["function"]["arguments"] = event.get("arguments", "")
        elif event_type == "response.output_item.done":
            item = event.get("item") or {}
            if item.get("type") == "reasoning":
                summary_text = reasoning_summary_text(item)
                if summary_text:
                    accumulated_reasoning.append(summary_text)
            elif item.get("type") == "function_call":
                item_id = item.get("id")
                if item_id in tool_calls_by_item:
                    tool_calls_by_item[item_id]["function"]["arguments"] = item.get("arguments", "")
        elif event_type == "response.completed":
            completed = event.get("response") or {}
    if completed is None:
        raise RuntimeError("Codex backend did not return response.completed")
    if accumulated_reasoning and not accumulated_text:
        accumulated_text = accumulated_reasoning
    tool_calls = [tool_calls_by_item[item_id] for item_id in tool_order if item_id in tool_calls_by_item]
    return response_to_chat_completion(completed, "".join(accumulated_text), tool_calls)


class Handler(BaseHTTPRequestHandler):
    auth = None
    endpoint = CODEX_ENDPOINT

    def log_message(self, fmt, *args):
        sys.stderr.write(f"[{self.log_date_time_string()}] {fmt % args}\n")

    def send_json(self, status, data):
        content = json.dumps(data, separators=(",", ":")).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(content)))
        self.send_header("Connection", "close")
        self.end_headers()
        self.wfile.write(content)

    def do_GET(self):
        if self.path in ("/health", "/v1/health"):
            self.send_json(200, {"ok": True})
            return
        if self.path.endswith("/models"):
            now = int(time.time())
            self.send_json(200, {
                "object": "list",
                "data": [
                    {"id": "gpt-5.4", "object": "model", "created": now, "owned_by": "chatgpt-codex"},
                    {"id": "gpt-5.3-codex", "object": "model", "created": now, "owned_by": "chatgpt-codex"},
                    {"id": "gpt-5.2", "object": "model", "created": now, "owned_by": "chatgpt-codex"},
                ],
            })
            return
        self.send_json(404, {"error": {"message": "not found"}})

    def upstream_request(self, payload):
        access_token, account_id = self.auth.get()
        content = json.dumps(payload, separators=(",", ":")).encode("utf-8")
        headers = {
            "Authorization": f"Bearer {access_token}",
            "Content-Type": "application/json",
            "Accept": "text/event-stream",
            "Accept-Language": "en-US,en;q=0.9",
            "Referer": "https://chatgpt.com/",
            "Origin": "https://chatgpt.com",
            "Sec-Fetch-Dest": "empty",
            "Sec-Fetch-Mode": "cors",
            "Sec-Fetch-Site": "same-origin",
            "Cache-Control": "no-cache",
            "Pragma": "no-cache",
            "DNT": "1",
            "OpenAI-Beta": "responses=experimental",
            "Originator": "codex_cli_rs",
            "Session_id": str(uuid.uuid4()),
            "User-Agent": USER_AGENT,
            "Content-Length": str(len(content)),
        }
        if account_id:
            headers["chatgpt-account-id"] = account_id
        req = urllib.request.Request(self.endpoint, data=content, headers=headers, method="POST")
        return urllib.request.urlopen(req, timeout=300)

    def stream_chunk(self, chunk):
        self.wfile.write(("data: " + json.dumps(chunk, separators=(",", ":")) + "\n\n").encode("utf-8"))
        self.wfile.flush()

    def stream_response(self, upstream, fallback_model):
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "close")
        self.end_headers()

        response_id = f"chatcmpl-{int(time.time())}"
        model = fallback_model
        created = int(time.time())
        sent_role = False
        saw_tool_call = False
        tool_indexes = {}

        def send_role():
            nonlocal sent_role
            if sent_role:
                return
            self.stream_chunk({
                "id": response_id,
                "object": "chat.completion.chunk",
                "created": created,
                "model": model,
                "choices": [{"index": 0, "delta": {"role": "assistant"}, "finish_reason": None}],
            })
            sent_role = True

        for raw in upstream:
            line = raw.decode("utf-8", errors="replace").strip()
            if not line.startswith("data: "):
                continue
            data = line[6:].strip()
            if not data or data == "[DONE]":
                continue
            try:
                event = json.loads(data)
            except json.JSONDecodeError:
                continue
            event_type = event.get("type")
            if event_type in ("response.created", "response.in_progress"):
                resp = event.get("response") or {}
                response_id = resp.get("id", response_id)
                model = resp.get("model", model)
                created = int(resp.get("created_at", created) or created)
                send_role()
            elif event_type == "response.output_text.delta":
                delta = event.get("delta", "")
                if delta:
                    send_role()
                    self.stream_chunk({
                        "id": response_id,
                        "object": "chat.completion.chunk",
                        "created": created,
                        "model": model,
                        "choices": [{"index": 0, "delta": {"content": delta}, "finish_reason": None}],
                    })
            elif event_type == "response.reasoning_text.delta":
                delta = event.get("delta", "")
                if delta:
                    send_role()
                    self.stream_chunk({
                        "id": response_id,
                        "object": "chat.completion.chunk",
                        "created": created,
                        "model": model,
                        "choices": [{"index": 0, "delta": {"reasoning": delta}, "finish_reason": None}],
                    })
            elif event_type == "response.output_item.added":
                item = event.get("item") or {}
                if item.get("type") == "reasoning":
                    summary_text = reasoning_summary_text(item)
                    if summary_text:
                        send_role()
                        self.stream_chunk({
                            "id": response_id,
                            "object": "chat.completion.chunk",
                            "created": created,
                            "model": model,
                            "choices": [{"index": 0, "delta": {"reasoning": summary_text}, "finish_reason": None}],
                        })
                elif item.get("type") == "function_call":
                    send_role()
                    saw_tool_call = True
                    item_id = item.get("id") or str(event.get("output_index", len(tool_indexes)))
                    tool_index = int(event.get("output_index", len(tool_indexes)) or 0)
                    tool_indexes[item_id] = tool_index
                    self.stream_chunk({
                        "id": response_id,
                        "object": "chat.completion.chunk",
                        "created": created,
                        "model": model,
                        "choices": [{
                            "index": 0,
                            "delta": {
                                "tool_calls": [{
                                    "index": tool_index,
                                    "id": item.get("call_id", item_id),
                                    "type": "function",
                                    "function": {"name": item.get("name", ""), "arguments": ""},
                                }],
                            },
                            "finish_reason": None,
                        }],
                    })
            elif event_type == "response.function_call_arguments.delta":
                item_id = event.get("item_id")
                if item_id in tool_indexes:
                    send_role()
                    self.stream_chunk({
                        "id": response_id,
                        "object": "chat.completion.chunk",
                        "created": created,
                        "model": model,
                        "choices": [{
                            "index": 0,
                            "delta": {
                                "tool_calls": [{
                                    "index": tool_indexes[item_id],
                                    "function": {"arguments": event.get("delta", "")},
                                }],
                            },
                            "finish_reason": None,
                        }],
                    })
            elif event_type == "response.completed":
                resp = event.get("response") or {}
                response_id = resp.get("id", response_id)
                model = resp.get("model", model)
                created = int(resp.get("created_at", created) or created)
                send_role()
                self.stream_chunk({
                    "id": response_id,
                    "object": "chat.completion.chunk",
                    "created": created,
                    "model": model,
                    "choices": [{"index": 0, "delta": {}, "finish_reason": "tool_calls" if saw_tool_call else "stop"}],
                    "usage": openai_usage(resp.get("usage")),
                })
                self.wfile.write(b"data: [DONE]\n\n")
                self.wfile.flush()
                return

        send_role()
        self.stream_chunk({
            "id": response_id,
            "object": "chat.completion.chunk",
            "created": created,
            "model": model,
            "choices": [{"index": 0, "delta": {}, "finish_reason": "tool_calls" if saw_tool_call else "stop"}],
        })
        self.wfile.write(b"data: [DONE]\n\n")
        self.wfile.flush()

    def do_POST(self):
        if "/chat/completions" not in self.path:
            self.send_json(404, {"error": {"message": "only /v1/chat/completions is supported"}})
            return

        try:
            length = int(self.headers.get("Content-Length", "0"))
            body = json.loads(self.rfile.read(length).decode("utf-8"))
            wants_stream = body.get("stream") is True
            payload = chat_to_responses(body)
            upstream = self.upstream_request(payload)
            if wants_stream:
                self.stream_response(upstream, payload.get("model", ""))
            else:
                raw = upstream.read()
                self.send_json(200, parse_completed_response(raw))
        except urllib.error.HTTPError as exc:
            err = exc.read().decode("utf-8", errors="replace")
            try:
                data = json.loads(err)
            except json.JSONDecodeError:
                data = {"error": {"message": err}}
            self.send_json(exc.code, data)
        except Exception as exc:
            self.send_json(500, {"error": {"message": str(exc)}})


def main():
    parser = argparse.ArgumentParser(description="OpenAI chat-completions shim for Codex ChatGPT OAuth")
    parser.add_argument("--host", default=os.environ.get("CODEX_CHATGPT_SHIM_HOST", "127.0.0.1"))
    parser.add_argument("--port", type=int, default=int(os.environ.get("CODEX_CHATGPT_SHIM_PORT", "4057")))
    parser.add_argument("--auth-json", default=os.environ.get("CODEX_AUTH_JSON", "~/.codex/auth.json"))
    parser.add_argument("--endpoint", default=os.environ.get("CODEX_CHATGPT_ENDPOINT", CODEX_ENDPOINT))
    args = parser.parse_args()

    Handler.auth = CodexAuth(args.auth_json)
    Handler.endpoint = args.endpoint
    server = ThreadingHTTPServer((args.host, args.port), Handler)
    sys.stderr.write(f"codex-chatgpt-openai-shim listening on http://{args.host}:{args.port}\n")
    server.serve_forever()


