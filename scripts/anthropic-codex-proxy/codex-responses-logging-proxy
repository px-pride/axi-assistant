#!/usr/bin/env python3
import argparse
import json
import sys
import threading
import time
import urllib.error
import urllib.request
import uuid
from datetime import UTC, datetime
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

DEFAULT_UPSTREAM_URL = "https://chatgpt.com/backend-api/codex/responses"
SENSITIVE_HEADER_TOKENS = ("authorization", "cookie")


def utc_timestamp():
    return datetime.now(UTC).strftime("%Y%m%dT%H%M%S.%fZ")


def redact_headers(headers):
    redacted = {}
    for name, value in headers.items():
        lower = name.lower()
        if any(token in lower for token in SENSITIVE_HEADER_TOKENS):
            redacted[name] = "<redacted>"
        else:
            redacted[name] = value
    return redacted


def parse_body(raw):
    text = raw.decode("utf-8", errors="replace")
    try:
        return {"kind": "json", "json": json.loads(text)}
    except json.JSONDecodeError:
        return {"kind": "text", "text": text}


def write_json(path, data):
    path.write_text(json.dumps(data, indent=2) + "\n")


class Handler(BaseHTTPRequestHandler):
    dump_dir = None
    upstream_url = DEFAULT_UPSTREAM_URL
    allow_shutdown = False

    def log_message(self, fmt, *args):
        sys.stderr.write(f"[{self.log_date_time_string()}] {fmt % args}\n")

    def send_json(self, status, data):
        content = json.dumps(data, separators=(",", ":")).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(content)))
        self.send_header("Connection", "close")
        self.end_headers()
        self.wfile.write(content)

    def do_GET(self):
        if self.path in ("/health", "/v1/health"):
            self.send_json(200, {"ok": True})
            return
        if self.path == "/shutdown" and self.allow_shutdown:
            self.send_json(200, {"ok": True})
            threading.Thread(target=self.server.shutdown, daemon=True).start()
            return
        self.send_json(404, {"error": {"message": "not found"}})

    def do_POST(self):
        if self.path != "/v1/responses":
            self.send_json(403, {"error": {"message": "only /v1/responses is supported"}})
            return

        started = time.time()
        request_id = f"{utc_timestamp()}-{uuid.uuid4().hex[:8]}"
        request_path = self.dump_dir / f"{request_id}-request.json"
        response_path = self.dump_dir / f"{request_id}-response.json"

        length = int(self.headers.get("Content-Length", "0"))
        request_body = self.rfile.read(length)
        incoming_headers = dict(self.headers.items())
        forward_headers = {
            name: value
            for name, value in incoming_headers.items()
            if name.lower() not in ("host", "content-length", "connection")
        }

        write_json(
            request_path,
            {
                "request_id": request_id,
                "method": "POST",
                "path": self.path,
                "upstream_url": self.upstream_url,
                "received_at": datetime.now(UTC).isoformat().replace("+00:00", "Z"),
                "headers": redact_headers(incoming_headers),
                "body": parse_body(request_body),
            },
        )

        request = urllib.request.Request(
            self.upstream_url,
            data=request_body,
            headers=forward_headers,
            method="POST",
        )

        try:
            with urllib.request.urlopen(request, timeout=300) as upstream:
                upstream_headers = dict(upstream.headers.items())
                content_type = upstream_headers.get("Content-Type", "")

                self.send_response(upstream.status)
                for name, value in upstream.headers.items():
                    if name.lower() in ("content-length", "connection", "transfer-encoding"):
                        continue
                    self.send_header(name, value)
                self.send_header("Connection", "close")
                self.end_headers()

                if "text/event-stream" in content_type:
                    raw_chunks = []
                    events = []
                    while True:
                        line = upstream.readline()
                        if not line:
                            break
                        raw_chunks.append(line)
                        decoded = line.decode("utf-8", errors="replace")
                        if decoded.startswith("data: "):
                            data = decoded[6:].strip()
                            if data:
                                if data == "[DONE]":
                                    events.append("[DONE]")
                                else:
                                    try:
                                        events.append(json.loads(data))
                                    except json.JSONDecodeError:
                                        events.append(data)
                        self.wfile.write(line)
                        self.wfile.flush()
                    response_body = b"".join(raw_chunks)
                    parsed_response = {
                        "kind": "sse",
                        "raw_text": response_body.decode("utf-8", errors="replace"),
                        "events": events,
                    }
                else:
                    response_body = upstream.read()
                    parsed_response = parse_body(response_body)
                    self.wfile.write(response_body)
                    self.wfile.flush()

                write_json(
                    response_path,
                    {
                        "request_id": request_id,
                        "status": upstream.status,
                        "reason": getattr(upstream, "reason", ""),
                        "received_at": datetime.now(UTC).isoformat().replace("+00:00", "Z"),
                        "duration_ms": round((time.time() - started) * 1000, 1),
                        "headers": redact_headers(upstream_headers),
                        "body": parsed_response,
                    },
                )
        except urllib.error.HTTPError as exc:
            error_body = exc.read()
            error_headers = dict(exc.headers.items())
            self.send_response(exc.code)
            for name, value in exc.headers.items():
                if name.lower() in ("content-length", "connection", "transfer-encoding"):
                    continue
                self.send_header(name, value)
            self.send_header("Connection", "close")
            self.end_headers()
            self.wfile.write(error_body)
            self.wfile.flush()
            write_json(
                response_path,
                {
                    "request_id": request_id,
                    "status": exc.code,
                    "reason": getattr(exc, "reason", ""),
                    "received_at": datetime.now(UTC).isoformat().replace("+00:00", "Z"),
                    "duration_ms": round((time.time() - started) * 1000, 1),
                    "headers": redact_headers(error_headers),
                    "body": parse_body(error_body),
                },
            )
        except Exception as exc:
            self.send_json(502, {"error": {"message": str(exc)}})
            write_json(
                response_path,
                {
                    "request_id": request_id,
                    "status": 502,
                    "received_at": datetime.now(UTC).isoformat().replace("+00:00", "Z"),
                    "duration_ms": round((time.time() - started) * 1000, 1),
                    "error": str(exc),
                },
            )


def main():
    parser = argparse.ArgumentParser(description="Local logging proxy for Codex /v1/responses traffic")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=0)
    parser.add_argument("--upstream-url", default=DEFAULT_UPSTREAM_URL)
    parser.add_argument("--dump-dir", default="/tmp/codex-responses-logs")
    parser.add_argument("--server-info")
    parser.add_argument("--http-shutdown", action="store_true")
    args = parser.parse_args()

    dump_dir = Path(args.dump_dir).expanduser()
    dump_dir.mkdir(parents=True, exist_ok=True)

    Handler.dump_dir = dump_dir
    Handler.upstream_url = args.upstream_url
    Handler.allow_shutdown = args.http_shutdown

    server = ThreadingHTTPServer((args.host, args.port), Handler)
    host, port = server.server_address

    if args.server_info:
        info_path = Path(args.server_info).expanduser()
        write_json(
            info_path,
            {
                "host": host,
                "port": port,
                "pid": Path("/proc/self").resolve().name if Path("/proc/self").exists() else None,
                "dump_dir": str(dump_dir),
                "upstream_url": args.upstream_url,
            },
        )

    sys.stderr.write(f"codex-responses-logging-proxy listening on http://{host}:{port}\n")
    server.serve_forever()


if __name__ == "__main__":
    main()
