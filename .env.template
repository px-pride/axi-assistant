DISCORD_TOKEN=<bot token>
ALLOWED_USER_IDS=<comma-separated Discord user IDs>
DISCORD_GUILD_ID=<your Discord server/guild ID>
SCHEDULE_TIMEZONE=US/Pacific
DEFAULT_CWD=<absolute path to this repo>
AXI_USER_DATA=<absolute path to user data directory>
# Hour (0-23) when a new "day" starts for planning purposes. Default: 0 (midnight).
# E.g., DAY_BOUNDARY_HOUR=7 means 3 AM Tuesday is still logically "Monday".
DAY_BOUNDARY_HOUR=0
# Set to 1 to auto-spawn a crash-handler agent on crash recovery.
# ENABLE_CRASH_HANDLER=1
# Set to 1 to enable automatic git rollback on startup crashes.
# ENABLE_ROLLBACK=1
DEFAULT_PACKS=purpose,direct-answers,minflow,timeouts,naming,record-handler-minflow
# Seconds idle before auto-sleeping an agent. Default: 60.
IDLE_SLEEP_SECONDS=300

# Optional: route Axi/Claude Code through the ChatGPT/Codex Anthropic proxy.
# See docs/chatgpt-anthropic-proxy.md.
# AXI_HARNESS=claude_code
# AXI_MODEL=gpt-5.4

# Optional: FlowCoder auto-wrap command.
# Unset defaults to soul. Use prompt for a transparent pass-through wrapper,
# or off to send messages directly through FlowCoder.
# AXI_FC_WRAP=prompt

# Optional local HTTP API / Prometheus exporter.
# HTTP_API_HOST=0.0.0.0
# HTTP_API_PORT=8787
# Required when HTTP_API_HOST is non-loopback. Bot refuses to start otherwise.
# HTTP_API_TOKEN=<long random secret, e.g. from `openssl rand -hex 32`>

# Discord wire-audit log. Writes logs/discord-wire.jsonl. Rotated at 10 MiB
# per file, keeping 5 backups (.1 through .5). Set to 0 to disable entirely.
# ENABLE_WIRE_LOG=1

