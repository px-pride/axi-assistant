DISCORD_TOKEN=<bot token>
ALLOWED_USER_IDS=<comma-separated Discord user IDs>
DISCORD_GUILD_ID=<your Discord server/guild ID>
SCHEDULE_TIMEZONE=US/Pacific
DEFAULT_CWD=/home/pride/coding-projects/personal-assistant
AXI_USER_DATA=/home/pride/axi-user-data
# Hour (0-23) when a new "day" starts for planning purposes. Default: 0 (midnight).
# E.g., DAY_BOUNDARY_HOUR=7 means 3 AM Tuesday is still logically "Monday".
DAY_BOUNDARY_HOUR=0
# Set to 1 to auto-spawn a crash-handler agent on crash recovery.
# ENABLE_CRASH_HANDLER=1
# Set to 1 to enable automatic git rollback on startup crashes.
# ENABLE_ROLLBACK=1
DEFAULT_PACKS=purpose,direct-answers,minflow,timeouts,naming,record-handler-minflow
# Seconds idle before auto-sleeping an agent. Default: 60.
IDLE_SLEEP_SECONDS=300
